rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow all read and write operations for authenticated users
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow read access to all files (for public data if needed)
    match /{allPaths=**} {
      allow read: if true;
    }
  }
}
